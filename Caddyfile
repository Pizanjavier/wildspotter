{
	email admin@wildspotter.app
	servers {
		protocols h1 h2 h3
	}
}

(common) {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		-Server
	}
	request_body {
		max_size 2MB
	}
}

api.wildspotter.app {
	import common

	@health path /health
	handle @health {
		reverse_proxy api:8000
	}

	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
		# Skip the noisy uptime pings
		format filter {
			wrap json
			fields {
				request>headers>Authorization delete
				request>headers>Cookie delete
			}
		}
		# Drop /health entries from the main log
	}
	log_skip /health

	reverse_proxy api:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

api-stage.wildspotter.app {
	import common

	@health path /health
	handle @health {
		reverse_proxy stage-api:8000
	}

	log_skip /health

	reverse_proxy stage-api:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
