# Copy to .env.stage on the server and fill in real values. Never commit .env.stage.

# Separate project name so Docker prefixes stage containers/volumes independently.
COMPOSE_PROJECT_NAME=wildspotter-stage

# Stage Postgres — different creds from prod even though the DB container is separate.
POSTGRES_USER=wildspotter_stage
POSTGRES_PASSWORD=CHANGE_ME_STAGE_PASSWORD
POSTGRES_DB=wildspotter_stage

# Points at the stage db service inside the stage stack.
DATABASE_URL=postgresql://wildspotter_stage:CHANGE_ME_STAGE_PASSWORD@db:5432/wildspotter_stage

# n8n on stage is disabled via compose profile; these are only used if you enable it.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STAGE_N8N_PASSWORD
N8N_HOST=n8n-stage.internal

ANTHROPIC_API_KEY=sk-ant-XXXX
SENTRY_DSN=

# Stage usually mirrors prod CORS but also allows the stage client builds.
ALLOWED_ORIGINS=https://app-stage.wildspotter.app,http://localhost:8081,http://localhost:19006

# Override these to point stage at a feature branch image without touching prod.
API_IMAGE=wildspotter-api
API_IMAGE_TAG=staging
WORKER_IMAGE=wildspotter-worker
WORKER_IMAGE_TAG=staging
