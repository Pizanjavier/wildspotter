---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
---
<Base title="Baja confirmada · WildSpotter" description="Te has dado de baja de la lista de WildSpotter." locale="es">
  <Nav locale="es" />
  <main class="min-h-screen flex items-center justify-center px-5">
    <div class="text-center max-w-xl">
      <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-[#B7A089] mb-4">/ BAJA CONFIRMADA</p>
      <h1 class="font-black text-[44px] md:text-[60px] leading-[0.98] tracking-[-0.02em] mb-5 text-[#F5EBD8]">Te hemos borrado.</h1>
      <p class="text-[#B7A089] text-[17px] mb-10 leading-relaxed">Ya no volverás a recibir correos nuestros. Si ha sido sin querer, puedes volver a apuntarte cuando quieras.</p>
      <a href="/" class="font-mono text-[12px] tracking-[0.2em] uppercase text-[#B7A089] hover:text-[#D97706] transition">← Volver al inicio</a>
    </div>
  </main>
</Base>
