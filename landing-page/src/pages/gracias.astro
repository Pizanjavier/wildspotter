---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
---
<Base title="Confirmado · WildSpotter" description="Registro confirmado." locale="es">
  <Nav locale="es" />
  <main class="min-h-screen flex items-center justify-center px-5 contour-bg relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] rounded-full border border-[#D97706]/10 animate-[pulse_4s_ease-in-out_infinite]"></div>
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-[#D97706]/15"></div>
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full border border-[#D97706]/20"></div>
    </div>
    <div class="text-center max-w-xl relative z-10">
      <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-[#D97706] mb-4">/ CONFIRMADO · RADAR ON</p>
      <h1 id="ws-title" class="font-black text-[44px] md:text-[64px] leading-[0.95] tracking-[-0.02em] mb-5 text-white">Estás dentro.</h1>
      <p id="ws-sub" class="text-[#A0836C] text-[18px] mb-10">Te avisaremos el día del lanzamiento con tu acceso prioritario.</p>
      <a href="/" class="font-mono text-[12px] tracking-[0.2em] uppercase text-[#A0836C] hover:text-[#D97706] transition">← Volver</a>
    </div>
  </main>
  <script is:inline>
    const pos = new URLSearchParams(location.search).get('pos');
    if (pos) {
      document.getElementById('ws-title').innerHTML = 'Eres el <span style="color:#D97706">#' + Number(pos) + '</span>';
      document.getElementById('ws-sub').textContent = 'Tu plaza está confirmada. Te avisaremos el día del lanzamiento.';
    }
  </script>
</Base>
