---
import Base from '@/layouts/Base.astro';
import Footer from '@/components/Footer.astro';
import Nav from '@/components/Nav.astro';
import { getDict } from '@/i18n';

const t = getDict('es');
---
<Base title="WildSpotter Beta — Consigue Premium de por Vida" description="Ayúdanos a probar WildSpotter durante 14 días y llévate Premium de por vida." locale="es">
  <Nav locale="es" hideBanner={true} t={t} />
  <div class="min-h-screen bg-[#0F0D0B] text-[#F5EBD8] flex flex-col pt-16">
    <main class="flex-grow flex items-center justify-center py-20 px-4">
      <div class="max-w-xl w-full border border-[#2d2822] bg-[#0F0D0B] rounded-2xl p-8 md:p-12 shadow-2xl relative overflow-hidden">
        
        {/* Subtle background glow */}
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[150%] h-[150%] bg-[#2F6B4A]/10 blur-[100px] rounded-full pointer-events-none -z-10"></div>

        <a href="/" class="text-[#B7A089] hover:text-white mb-8 inline-flex items-center gap-2 transition-colors font-medium">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Volver
        </a>

        <div class="mb-8">
          <div class="inline-block bg-[#F5EBD8]/10 text-[#F5EBD8] px-3 py-1 rounded-full font-mono text-[11px] mb-6">
            {t.beta.slots.replace('{count}', '11')}
          </div>
          <h1 class="text-3xl md:text-4xl font-black font-sans tracking-tight mb-4 text-[#E8D9BF] leading-tight">
            {t.beta.modalTitle}
          </h1>
          <p class="text-[#B7A089] text-[16px] md:text-[18px] leading-relaxed">
            {t.beta.modalDesc}
          </p>
        </div>
        
        <div class="flex flex-col gap-4 relative z-10">
          <div class="bg-[#1A1713] p-5 rounded-xl border border-[#2d2822] hover:border-[#4ADE80]/30 transition-colors">
            <div class="text-[#849a62] font-mono text-[11px] mb-2 uppercase tracking-[0.15em] font-semibold">Paso 1</div>
            <p class="text-[15px] leading-relaxed">{t.beta.step1} <a href="https://groups.google.com/g/wildspotter-beta" target="_blank" rel="noopener noreferrer" class="text-white underline font-medium hover:text-[#4ADE80] transition-colors">{t.beta.step1Link}</a></p>
          </div>
          
          <div class="bg-[#1A1713] p-5 rounded-xl border border-[#2d2822] hover:border-[#4ADE80]/30 transition-colors">
            <div class="text-[#849a62] font-mono text-[11px] mb-2 uppercase tracking-[0.15em] font-semibold">Paso 2</div>
            <p class="text-[15px] leading-relaxed">{t.beta.step2} <a href="https://play.google.com/apps/testing/com.wildspotter.app" target="_blank" rel="noopener noreferrer" class="text-white underline font-medium hover:text-[#4ADE80] transition-colors">{t.beta.step2Link}</a></p>
          </div>

          <div class="bg-[#1A1713] p-5 rounded-xl border border-[#2d2822] hover:border-[#4ADE80]/30 transition-colors">
             <div class="text-[#849a62] font-mono text-[11px] mb-2 uppercase tracking-[0.15em] font-semibold">Paso 3</div>
            <p class="text-[15px] leading-relaxed">{t.beta.step3}</p>
          </div>
        </div>
      </div>
    </main>
    <Footer t={t} />
  </div>
</Base>
