---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import Problem from '@/components/Problem.astro';
import Pipeline from '@/components/Pipeline.astro';
import LegalTrust from '@/components/LegalTrust.astro';
import SpotAnatomy from '@/components/SpotAnatomy.astro';
import Principles from '@/components/Principles.astro';
import Vibe from '@/components/Vibe.astro';
import Offer from '@/components/Offer.astro';
import SecondCTA from '@/components/SecondCTA.astro';
import Footer from '@/components/Footer.astro';
import { getDict } from '@/i18n';

const t = getDict('en');
---
<Base title="WildSpotter — Find what no one has shared" description="A radar for vanlifers. Cross-checks official data to find wild overnight spots in Spain. Free on iOS, coming soon to Android." locale="en">
  <Nav locale="en" />
  <main>
    <Hero t={t} locale="en" />
    <div class="topo"></div>
    <Problem t={t} />
    <Pipeline t={t} />
    <LegalTrust t={t} />
    <SpotAnatomy t={t} />
    <Principles t={t} />
    <Vibe t={t} />
    <Offer t={t} />
    <SecondCTA t={t} locale="en" />
  </main>
  <Footer t={t} />
</Base>
