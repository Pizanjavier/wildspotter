---
import '@/styles/global.css';
import type { Locale } from '@/i18n';

interface Props {
  title: string;
  description: string;
  locale: Locale;
}
const { title, description, locale } = Astro.props;
const alt = locale === 'es' ? '/en/' : '/';
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="theme-color" content="#0F0D0B" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="WildSpotter" />
    <link rel="alternate" hreflang="es" href="https://wildspotter.app/" />
    <link rel="alternate" hreflang="en" href="https://wildspotter.app/en/" />
    <link rel="alternate" hreflang="x-default" href="https://wildspotter.app/" />
    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="icon" type="image/png" href="/logo.png" />
    <script define:vars={{ alt }} is:inline>
      // Preserve scroll position across language switch
      window.__wsSwitchLang = () => {
        sessionStorage.setItem('ws_scroll', String(window.scrollY));
        window.location.href = alt;
      };
      window.addEventListener('DOMContentLoaded', () => {
        const s = sessionStorage.getItem('ws_scroll');
        if (s) { window.scrollTo(0, parseInt(s, 10)); sessionStorage.removeItem('ws_scroll'); }
      });
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
    <script is:inline>
      // Scroll reveal IntersectionObserver
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
