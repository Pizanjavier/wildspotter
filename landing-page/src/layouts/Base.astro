---
import '@/styles/global.css';
import type { Locale } from '@/i18n';

interface Props {
  title: string;
  description: string;
  locale: Locale;
}
const { title, description, locale } = Astro.props;
const alt = locale === 'es' ? '/en/' : '/';
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="theme-color" content="#F4EFE3" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="WildSpotter" />
    <link rel="alternate" hreflang="es" href="https://wildspotter.app/" />
    <link rel="alternate" hreflang="en" href="https://wildspotter.app/en/" />
    <link rel="alternate" hreflang="x-default" href="https://wildspotter.app/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Geist+Mono:wght@300;400;500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <script define:vars={{ alt }} is:inline>
      window.__wsSwitchLang = () => {
        sessionStorage.setItem('ws_scroll', String(window.scrollY));
        window.location.href = alt;
      };
      window.addEventListener('DOMContentLoaded', () => {
        const s = sessionStorage.getItem('ws_scroll');
        if (s) { window.scrollTo(0, parseInt(s, 10)); sessionStorage.removeItem('ws_scroll'); }
      });
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
    <script is:inline>
      function wsInit() {
        // Scroll reveal — single observer for all fade-up elements
        var io = new IntersectionObserver(function(entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) {
              entries[i].target.classList.add('in');
              io.unobserve(entries[i].target);
            }
          }
        }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
        document.querySelectorAll('.fade-up').forEach(function(el) { io.observe(el); });

        // Mobile sticky CTA
        var sticky = document.getElementById('mobileSticky');
        if (sticky) {
          var heroEl = document.querySelector('.hero');
          if (heroEl) {
            var stickyObs = new IntersectionObserver(function(entries) {
              entries.forEach(function(e) { sticky.classList.toggle('show', !e.isIntersecting); });
            }, { threshold: 0 });
            stickyObs.observe(heroEl);
          }
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', wsInit);
      } else {
        wsInit();
      }
    </script>
  </body>
</html>
