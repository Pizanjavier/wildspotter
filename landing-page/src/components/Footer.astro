---
import type { Dict } from '@/i18n/es';
interface Props { t: Dict }
const { t } = Astro.props;
---
<footer class="px-5 md:px-10 py-20 border-t border-white/5">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/logo.png" alt="WildSpotter" width="28" height="28" class="h-7 w-7 object-contain" />
          <span class="font-sans font-black text-[14px] tracking-[0.02em] text-[#F5EBD8]">{t.footer.tag}</span>
        </div>
        <p class="text-[#B7A089] text-[15px] leading-[1.5] max-w-[380px]">{t.footer.sub}</p>
      </div>
      <nav class="flex flex-wrap gap-x-8 gap-y-3 text-[14px]">
        {t.footer.links.map((l) => (
          <a href={l.href} class="text-[#B7A089] hover:text-[#D97706] transition-colors">{l.label}</a>
        ))}
      </nav>
    </div>
    <div class="pt-8 border-t border-white/[0.05] flex items-center justify-between text-[12px] text-[#B7A089]/60">
      <span>{t.footer.copyright}</span>
      <span class="font-mono tracking-wider">ES · v0.1</span>
    </div>
  </div>
</footer>
