---
import type { Dict } from '@/i18n/es';
interface Props { t: Dict }
const { t } = Astro.props;
---
<footer style="padding:48px 0 64px;border-top:1px solid var(--line);">
  <div class="container" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px;">
    <div class="brand" style="display:flex;align-items:center;gap:11px;font-family:var(--mono);font-size:13px;letter-spacing:.18em;font-weight:600;color:var(--ink);">
      <img src="/logo.png" alt="WildSpotter" width="22" height="22" style="border-radius:4px;" />
      {t.footer.tag}
    </div>
    <nav style="display:flex;gap:24px;font-family:var(--mono);font-size:12px;color:var(--ink-3);letter-spacing:.1em;text-transform:uppercase;font-weight:500;">
      {t.footer.links.map((l) => (
        <a href={l.href} style="transition:color .2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-3)'">{l.label}</a>
      ))}
    </nav>
    <div style="font-family:var(--mono);font-size:11px;color:var(--ink-faint);letter-spacing:.12em;text-transform:uppercase;">
      {t.footer.copyright} · {t.locale === 'es' ? 'Hecho en España con cariño' : 'Built in Spain with care'}
    </div>
  </div>
</footer>

<style>
  @media (max-width: 880px) {
    footer { padding: 32px 0 110px !important; }
    footer .container { flex-direction: column; align-items: flex-start; gap: 14px; }
  }
</style>
