---
import type { Dict } from '@/i18n/es';
interface Props { t: Dict }
const { t } = Astro.props;
---
<section class="relative px-5 md:px-10 py-32 md:py-48 overflow-hidden">
  <div class="absolute inset-0" style="background: linear-gradient(180deg, #0F0D0B 0%, #1A120B 50%, #0F0D0B 100%);"></div>
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(90deg, #D97706 0 1px, transparent 1px 80px), repeating-linear-gradient(0deg, #D97706 0 1px, transparent 1px 80px);"></div>

  <div class="relative max-w-[1280px] mx-auto">
    <p class="reveal font-mono text-[11px] tracking-[0.3em] uppercase text-[#D97706] mb-6">Cómo funciona</p>
    <h2 class="reveal font-sans font-black text-[40px] sm:text-[56px] md:text-[84px] leading-[1.02] tracking-[-0.03em] display-cream mb-20 md:mb-28 max-w-[900px]" data-delay="1">
      {t.pipeline.title}
    </h2>

    <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12">
      {t.pipeline.stages.map((st, i) => (
        <li class="reveal group relative pt-8 border-t border-white/8 hover:border-[#D97706]/60 transition-colors" data-delay={String((i % 3) + 1)}>
          <div class="flex items-center gap-4 mb-5">
            <span class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-[#D97706]/50 font-mono text-[13px] text-[#D97706] group-hover:bg-[#D97706]/10 transition-colors">{st.n}</span>
            <h3 class="font-sans font-black text-[28px] md:text-[34px] leading-none display-cream tracking-[-0.02em]">{st.k}</h3>
          </div>
          <p class="text-[15px] md:text-[17px] leading-[1.6] text-[#B7A089] max-w-[360px]">{st.d}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
