---
import type { Dict } from '@/i18n/es';
import { EmailForm } from '@/islands/EmailForm';
interface Props { t: Dict; locale: 'es' | 'en' }
const { t, locale } = Astro.props;
---
<section class="relative px-5 md:px-10 py-32 md:py-48 overflow-hidden">
  <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline preload="none" aria-hidden="true">
    <source src="/videos/cta.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-[#0F0D0B]/80"></div>
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 900px 500px at center, rgba(217,119,6,0.18) 0%, rgba(15,13,11,0) 65%);"></div>
  <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, #0F0D0B 0%, transparent 15%, transparent 85%, #0F0D0B 100%);"></div>

  <div class="relative max-w-[820px] mx-auto text-center">
    <p class="reveal font-mono text-[11px] tracking-[0.3em] uppercase text-[#D97706] mb-6">Waitlist</p>
    <h2 class="reveal font-sans font-black text-[40px] sm:text-[56px] md:text-[72px] leading-[1.02] tracking-[-0.025em] display-cream mb-8" data-delay="1">{t.cta2.title}</h2>
    <p class="reveal text-[18px] md:text-[21px] leading-[1.55] text-[#F5EBD8]/85 mb-14" data-delay="2">{t.cta2.sub}</p>
    <div class="reveal flex justify-center" data-delay="3">
      <EmailForm client:visible copy={t.hero} locale={locale} variant="footer" />
    </div>
  </div>
</section>
