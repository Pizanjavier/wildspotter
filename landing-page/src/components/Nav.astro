---
import { LAUNCH_CONFIG } from '@/config';

const { locale } = Astro.props as { locale: 'es' | 'en' };
const iosUrl = LAUNCH_CONFIG.IOS_STORE_URL || '#';
const androidUrl = LAUNCH_CONFIG.ANDROID_STORE_URL || '#';
---
<nav class="top">
  <div class="container row">
    <a href={locale === 'es' ? '/' : '/en/'} class="brand">
      <img src="/logo.png" alt="WildSpotter" width="26" height="26" style="border-radius:6px;" />
      WILDSPOTTER
    </a>
    <div style="display:flex;align-items:center;gap:24px">
      <div class="lang">
        <a
          href="/"
          class={locale === 'es' ? 'on' : ''}
          onclick="sessionStorage.setItem('ws_scroll',String(window.scrollY))"
        >ES</a>
        <a
          href="/en/"
          class={locale === 'en' ? 'on' : ''}
          onclick="sessionStorage.setItem('ws_scroll',String(window.scrollY))"
        >EN</a>
      </div>
      <a href={'#download'} class="btn btn-primary nav-cta">
        {locale === 'es' ? 'Descargar' : 'Download'}
      </a>
    </div>
  </div>
</nav>
