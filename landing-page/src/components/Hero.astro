---
import type { Dict } from '@/i18n/es';
import { LAUNCH_CONFIG } from '@/config';
import { EmailForm } from '@/islands/EmailForm';
interface Props { t: Dict; locale: 'es' | 'en' }
const { t, locale } = Astro.props;
const iosUrl = LAUNCH_CONFIG.IOS_STORE_URL || '#';
const showAndroidForm = !LAUNCH_CONFIG.ANDROID_LIVE;
---
<section class="hero" style="position:relative;padding:72px 0 100px;overflow:hidden;" id="hero-section">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-fallback"></div>
  </div>
  <div class="container" style="position:relative;z-index:2;">
    <div class="hero-grid">
      <!-- Text column -->
      <div>
        <span class="eyebrow"><span class="live-dot"></span>{locale === 'es' ? 'Gratis en iOS · 80 000+ spots analizados' : 'Free on iOS · 80,000+ spots analyzed'}</span>
        <h1 class="h-display" style="margin:22px 0 26px;">
          {locale === 'es' ? (
            <Fragment>
              <span class="reveal-word">Encuentra</span><br/>
              <span class="reveal-word">lo&nbsp;que&nbsp;</span><span class="reveal-word"><em class="italic">nadie</em></span><br/>
              <span class="reveal-word">ha&nbsp;compartido.</span>
            </Fragment>
          ) : (
            <Fragment>
              <span class="reveal-word">Find</span>&nbsp;<span class="reveal-word">what</span><br/>
              <span class="reveal-word"><em class="italic">no&nbsp;one</em></span><br/>
              <span class="reveal-word">has&nbsp;shared.</span>
            </Fragment>
          )}
        </h1>
        <p class="lede">{t.hero.subtitle}</p>
        <div class="cta-row" style="display:flex;align-items:center;gap:14px;margin-top:36px;flex-wrap:wrap;">
          <a href={iosUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            <svg width="14" height="16" viewBox="0 0 14 16" fill="currentColor"><path d="M11.5 8.5c0-1.4.7-2.4 1.7-3.1-.6-.9-1.5-1.4-2.7-1.5-1.1-.1-2.3.7-2.9.7-.6 0-1.6-.6-2.6-.6-1.4 0-2.7.8-3.4 2.1-1.5 2.5-.4 6.2 1 8.3.7 1 1.5 2.1 2.6 2.1 1 0 1.4-.6 2.7-.6 1.2 0 1.6.6 2.7.6 1.1 0 1.8-1 2.5-2 .8-1.1 1.1-2.2 1.1-2.3-.1 0-2.2-.8-2.2-3.3zM9.7 2.6c.5-.6.9-1.5.8-2.4-.8 0-1.7.5-2.2 1.1-.5.5-.9 1.4-.8 2.3.9.1 1.7-.4 2.2-1z"/></svg>
            {locale === 'es' ? 'Descargar gratis · App Store' : 'Download free · App Store'}
          </a>
          {showAndroidForm && (
            <a href="#android" class="btn btn-dark">{locale === 'es' ? 'Avísame · Android' : 'Notify me · Android'}</a>
          )}
        </div>
        <div style="display:flex;gap:36px;margin-top:32px;font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.14em;text-transform:uppercase;" class="hero-meta">
          <div><b style="display:block;color:var(--ink);font-size:22px;font-family:var(--serif);font-weight:400;letter-spacing:-0.02em;margin-bottom:4px;text-transform:none;">0 €</b>{locale === 'es' ? 'Sin anuncios' : 'No ads'}</div>
          <div><b style="display:block;color:var(--ink);font-size:22px;font-family:var(--serif);font-weight:400;letter-spacing:-0.02em;margin-bottom:4px;text-transform:none;">5</b>{locale === 'es' ? 'Fuentes oficiales' : 'Official sources'}</div>
          <div><b style="display:block;color:var(--ink);font-size:22px;font-family:var(--serif);font-weight:400;letter-spacing:-0.02em;margin-bottom:4px;text-transform:none;">0—100</b>{locale === 'es' ? 'Puntuación por spot' : 'Score per spot'}</div>
        </div>
      </div>

      <!-- Phone illustration -->
      <div class="phone-stage" style="position:relative;display:flex;justify-content:center;align-items:center;">
        <!-- Floating badges -->
        <div class="float-badge b1" style="position:absolute;background:white;border:1px solid var(--line);border-radius:14px;padding:12px 16px;display:flex;align-items:center;gap:12px;box-shadow:0 8px 24px rgba(60,40,15,.08);font-size:13px;top:14%;left:-10%;">
          <div style="width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;background:var(--green);">87</div>
          <div><b style="display:block;font-weight:600;">{locale === 'es' ? 'Puntuación' : 'Score'}</b><span style="color:var(--ink-3);font-size:11px;font-family:var(--mono);letter-spacing:.06em;">0—100</span></div>
        </div>
        <div class="float-badge b2" style="position:absolute;background:white;border:1px solid var(--line);border-radius:14px;padding:12px 16px;display:flex;align-items:center;gap:12px;box-shadow:0 8px 24px rgba(60,40,15,.08);font-size:13px;bottom:18%;right:-8%;">
          <div style="width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;background:var(--orange);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          </div>
          <div><b style="display:block;font-weight:600;">{locale === 'es' ? 'Veredicto legal' : 'Legal verdict'}</b><span style="color:var(--ink-3);font-size:11px;font-family:var(--mono);letter-spacing:.06em;">Catastro · Natura · Costas</span></div>
        </div>

        <div class="phone" style="width:320px;height:660px;background:var(--cream);border-radius:48px;border:8px solid #1a160f;padding:12px;box-shadow:0 30px 80px rgba(60,40,15,.18),0 8px 20px rgba(60,40,15,.08);position:relative;transform:rotate(-3deg);">
          <div style="width:100%;height:100%;border-radius:36px;background:var(--cream);overflow:hidden;position:relative;">
            <!-- Notch -->
            <div class="phone-notch" style="position:absolute;left:50%;top:8px;transform:translateX(-50%);width:96px;height:26px;background:#1a160f;border-radius:14px;z-index:5;"></div>
            <!-- Status bar -->
            <div style="position:absolute;left:0;right:0;top:14px;padding:0 28px;display:flex;justify-content:space-between;font-family:var(--sans);font-size:14px;font-weight:600;color:var(--ink);z-index:6;">
              <span>11:22</span>
              <span style="display:flex;align-items:center;gap:5px;">····
                <span style="width:22px;height:11px;border:1px solid var(--ink);border-radius:3px;padding:1px;display:inline-block;position:relative;"><span style="display:block;width:90%;height:100%;background:var(--ink);border-radius:1px;"></span></span>
              </span>
            </div>
            <!-- Faux map -->
            <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 20%,#DCE7CC 0%,transparent 40%),radial-gradient(ellipse at 80% 60%,#C9DDE8 0%,transparent 50%),radial-gradient(ellipse at 60% 80%,#E5DCC2 0%,transparent 50%),linear-gradient(180deg,#ECE3CB 0%,#E5DBBE 100%);"></div>
            <div style="position:absolute;left:60%;right:0;bottom:0;height:42%;background:linear-gradient(135deg,#B7D4DD 0%,#93BFCB 100%);clip-path:polygon(20% 0,100% 25%,100% 100%,0 100%,0 60%);"></div>
            <!-- Score pips -->
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18);background:var(--green);left:18%;top:36%;">52</div>
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18);background:var(--teal);left:34%;top:42%;">28</div>
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18);background:var(--green);left:48%;top:38%;">71</div>
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18),0 0 0 2px white,0 0 0 4px var(--red);background:var(--green);left:62%;top:44%;">38</div>
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18);background:var(--green);left:30%;top:54%;">63</div>
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18);background:var(--green);left:52%;top:58%;">87</div>
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18);background:var(--teal);left:40%;top:64%;">45</div>
            <div class="score-pip" style="position:absolute;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;font-weight:700;color:white;box-shadow:0 2px 6px rgba(20,15,5,.18);background:var(--green);left:24%;top:68%;">59</div>
            <!-- Search bar -->
            <div class="phone-search" style="position:absolute;left:14px;right:14px;top:54px;background:white;border-radius:20px;padding:11px 16px;display:flex;align-items:center;gap:8px;box-shadow:0 2px 8px rgba(20,15,5,.06);font-size:13px;color:var(--ink-faint);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--ink-3);"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
              <span>{locale === 'es' ? 'Buscar ubicación...' : 'Search location...'}</span>
            </div>
            <!-- Filters -->
            <div class="phone-filters" style="position:absolute;left:14px;top:104px;display:flex;gap:8px;">
              <span style="padding:7px 14px;border-radius:999px;font-size:12px;font-weight:600;background:var(--orange);color:white;box-shadow:0 1px 4px rgba(20,15,5,.06);">{locale === 'es' ? '= Filtros' : '= Filters'}</span>
              <span style="padding:7px 14px;border-radius:999px;font-size:12px;font-weight:600;background:white;color:var(--ink);box-shadow:0 1px 4px rgba(20,15,5,.06);">{locale === 'es' ? '<=8% pendiente' : '<=8% slope'}</span>
            </div>
            <!-- Scan button -->
            <div class="phone-scan" style="position:absolute;left:50%;bottom:130px;transform:translateX(-50%);background:var(--orange);color:white;padding:13px 24px;border-radius:999px;font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 6px 18px rgba(224,122,31,.4);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="2.5"/><path d="M16 12a4 4 0 11-8 0M19 12a7 7 0 11-14 0"/></svg>
              {locale === 'es' ? 'Escanear zona' : 'Scan area'}
            </div>
            <!-- Bottom sheet -->
            <div class="phone-sheet" style="position:absolute;left:0;right:0;bottom:0;background:var(--cream);border-top-left-radius:24px;border-top-right-radius:24px;padding:16px 18px 22px;height:120px;box-shadow:0 -10px 30px rgba(20,15,5,.08);">
              <div style="width:36px;height:4px;background:var(--ink-faint);border-radius:2px;margin:0 auto 12px;"></div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;font-family:var(--mono);font-size:11px;letter-spacing:.06em;font-weight:600;color:var(--ink);">
                <span>100 SPOTS</span>
                <span style="color:var(--ink-3);font-weight:400;">— · — N · — · — W</span>
              </div>
              <div style="display:flex;align-items:center;gap:12px;background:white;border-radius:14px;padding:10px 14px;">
                <div style="width:36px;height:36px;border-radius:50%;background:var(--green);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;">87</div>
                <div>
                  <div style="font-weight:600;font-size:14px;">Mirador · spot 087</div>
                  <div style="font-size:11px;color:var(--ink-3);margin-top:2px;">{locale === 'es' ? 'Final de pista · 0.0% pendiente' : 'Track end · 0.0% slope'}</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .hero { padding: 36px 0 64px !important; }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .phone-stage { display: none; }
    .hero-meta { gap: 18px !important; flex-wrap: wrap; margin-top: 24px !important; }
    .hero-meta div { flex: 1; min-width: 0; }
    .hero-meta :global(b) { font-size: 18px !important; }
    .cta-row :global(.btn-dark) { display: none; }
  }
</style>
