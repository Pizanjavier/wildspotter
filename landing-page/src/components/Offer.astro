---
import type { Dict } from '@/i18n/es';
interface Props { t: Dict }
const { t } = Astro.props;
---
<section class="relative px-5 md:px-10 py-32 md:py-48 overflow-hidden">
  <div class="absolute inset-0" style="background: linear-gradient(180deg, #0F0D0B 0%, #1A130D 100%);"></div>
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 1100px 700px at 50% 30%, rgba(217,119,6,0.18), transparent 65%);"></div>

  <div class="relative max-w-[820px] mx-auto text-center">
    <p class="reveal font-mono text-[11px] tracking-[0.3em] uppercase text-[#D97706] mb-6">{t.offer.eyebrow}</p>
    <h2 class="reveal font-sans font-black text-[36px] sm:text-[52px] md:text-[68px] leading-[1.02] tracking-[-0.03em] display-cream mb-8" data-delay="1">
      {t.offer.title}
    </h2>
    <p class="reveal text-[17px] md:text-[19px] leading-[1.55] text-[#B7A089] mb-14 max-w-[640px] mx-auto" data-delay="2">
      {t.offer.sub}
    </p>

    <div class="reveal grid sm:grid-cols-2 gap-6 md:gap-8 max-w-[680px] mx-auto" data-delay="3">
      {t.offer.highlights.map((item) => (
        <div class="p-6 md:p-8 rounded-xl bg-[#1A130D]/80 backdrop-blur-sm border border-white/[0.08] text-left">
          <div class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#D97706] mb-3">{item.label}</div>
          <p class="text-[15px] text-[#E8D9BF] leading-[1.55]">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
