# Copy to .env.prod on the server and fill in real values. Never commit .env.prod.

# Docker Compose project name — isolates resources from the stage stack.
COMPOSE_PROJECT_NAME=wildspotter-prod

# Postgres — generate password with: openssl rand -base64 32
POSTGRES_USER=wildspotter
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=wildspotter

# DATABASE_URL must match the creds above; host is the compose service name `db`.
DATABASE_URL=postgresql://wildspotter:CHANGE_ME_STRONG_PASSWORD@db:5432/wildspotter

# n8n admin — generate password with: openssl rand -base64 24
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD
N8N_HOST=n8n.internal

# Anthropic API key for the ai_vision_labeler worker
ANTHROPIC_API_KEY=sk-ant-XXXX

# Sentry DSN for backend error tracking (optional — leave blank to disable)
SENTRY_DSN=

# CORS allowlist consumed by backend/src/index.ts (CORS_ORIGINS).
# Comma-separated origins. Include the Android app scheme and any web dev origin.
# Landing page wildspotter.app does NOT hit the API, so it is not listed.
ALLOWED_ORIGINS=https://app.wildspotter.app,http://localhost:8081,http://localhost:19006

# Image tags — bump these when promoting a build. Default `latest` is fine for a single-server deploy.
API_IMAGE=wildspotter-api
API_IMAGE_TAG=latest
WORKER_IMAGE=wildspotter-worker
WORKER_IMAGE_TAG=latest
